
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application with specific profile data and role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer", "driver", "business"] },
        "profilePic": { "type": "string" },
        "city": { "type": "string" },
        "isBlocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "driver": {
      "title": "Driver",
      "description": "A partner driver profile with vehicle and status details.",
      "type": "object",
      "properties": {
        "driverId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "vehicleType": { "type": "string", "enum": ["e-rickshaw", "cab"] },
        "isOnline": { "type": "boolean" },
        "isAvailable": { "type": "boolean" },
        "currentLat": { "type": "number" },
        "currentLng": { "type": "number" },
        "rating": { "type": "number" },
        "totalTrips": { "type": "number" },
        "city": { "type": "string" },
        "documents": {
          "type": "object",
          "properties": {
            "dl": { "type": "string" },
            "rc": { "type": "string" },
            "insurance": { "type": "string" }
          }
        },
        "fleetId": { "type": "string", "nullable": true },
        "kycVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["driverId", "name", "phone", "vehicleNumber", "vehicleType"]
    },
    "ride": {
      "title": "Ride",
      "description": "A ride booking record with geolocation and payment tracking.",
      "type": "object",
      "properties": {
        "rideId": { "type": "string" },
        "customerId": { "type": "string" },
        "driverId": { "type": "string", "nullable": true },
        "status": { "type": "string", "enum": ["requested", "accepted", "started", "completed", "cancelled"] },
        "pickup": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "dropoff": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "fare": { "type": "number" },
        "distance": { "type": "number" },
        "duration": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["wallet", "upi", "cash"] },
        "paymentStatus": { "type": "string" },
        "razorpayOrderId": { "type": "string" },
        "razorpayPaymentId": { "type": "string" },
        "otp": { "type": "string" },
        "otpUsed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "driver_location": {
      "title": "Driver Location",
      "description": "Real-time location data for a driver.",
      "type": "object",
      "properties": {
        "driverId": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "heading": { "type": "number" },
        "speed": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "isOnline": { "type": "boolean" }
      },
      "required": ["driverId", "lat", "lng", "isOnline"]
    },
    "wallet": {
      "title": "Wallet",
      "description": "User financial balance.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "balance": { "type": "number" }
      }
    },
    "transaction": {
      "title": "Transaction",
      "description": "Financial transaction record.",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "razorpayPaymentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["transactionId", "userId", "type", "amount", "status"]
    },
    "fleet": {
      "title": "Fleet",
      "description": "A collection of vehicles and drivers managed by a business owner.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "ownerName": { "type": "string" },
        "fleetName": { "type": "string" },
        "vehicles": { "type": "array", "items": { "type": "string" } },
        "drivers": { "type": "array", "items": { "type": "string" } },
        "totalEarnings": { "type": "number" },
        "commissionPaid": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "ownerName", "fleetName"]
    },
    "review": {
      "title": "Review",
      "description": "User feedback for a completed ride.",
      "type": "object",
      "properties": {
        "rideId": { "type": "string" },
        "driverId": { "type": "string" },
        "customerId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rideId", "driverId", "customerId", "rating"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "User profile data."
    },
    "/drivers/{driverId}": {
      "schema": { "$ref": "#/backend/entities/driver" },
      "description": "Driver profile and status data."
    },
    "/rides/{rideId}": {
      "schema": { "$ref": "#/backend/entities/ride" },
      "description": "Ride booking records."
    },
    "/driver_locations/{driverId}": {
      "schema": { "$ref": "#/backend/entities/driver_location" },
      "description": "Real-time driver GPS data."
    },
    "/wallets/{userId}": {
      "schema": { "$ref": "#/backend/entities/wallet" },
      "description": "User wallet balances."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/backend/entities/transaction" },
      "description": "Financial logs."
    },
    "/fleets/{fleetId}": {
      "schema": { "$ref": "#/backend/entities/fleet" },
      "description": "Fleet and business management data."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/backend/entities/review" },
      "description": "User reviews and ratings for rides."
    }
  }
}
