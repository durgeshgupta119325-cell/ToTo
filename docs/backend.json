{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application with role-based access.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer", "driver"] },
        "mobile": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "ride": {
      "title": "Ride",
      "description": "A ride booking record.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "status": { "type": "string" },
        "fare": { "type": "number" },
        "otp": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "wallet": {
      "title": "Wallet",
      "description": "User financial balance.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "balance": { "type": "number" }
      }
    },
    "transaction": {
      "title": "Transaction",
      "description": "Financial transaction record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "User profile data."
    },
    "/rides/{rideId}": {
      "schema": { "$ref": "#/backend/entities/ride" },
      "description": "Ride booking records."
    },
    "/wallets/{userId}": {
      "schema": { "$ref": "#/backend/entities/wallet" },
      "description": "User wallet balances."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/backend/entities/transaction" },
      "description": "Financial logs."
    }
  }
}