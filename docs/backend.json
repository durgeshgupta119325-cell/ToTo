
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        }
      },
      "required": [
        "name",
        "email"
      ]
    },
    "ride": {
      "title": "Ride",
      "description": "A ride booking record.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "pickup": { "type": "string" },
        "destination": { "type": "string" },
        "status": { 
          "type": "string",
          "enum": ["pending", "searching_all", "accepted", "arrived", "started", "completed", "cancelled"]
        },
        "fare": { "type": "number" },
        "otp": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "distance": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/user"
      },
      "description": "Stores user profile information."
    },
    "/rides/{rideId}": {
      "schema": {
        "$ref": "#/backend/entities/ride"
      },
      "description": "Stores ride booking and status information."
    }
  }
}
