
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application with specific profile data and role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer", "driver", "business"] },
        "profilePic": { "type": "string" },
        "city": { "type": "string" },
        "isBlocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "driver": {
      "title": "Driver",
      "description": "A partner driver profile with vehicle and status details.",
      "type": "object",
      "properties": {
        "driverId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "vehicleType": { "type": "string", "enum": ["e-rickshaw", "cab"] },
        "isOnline": { "type": "boolean" },
        "isAvailable": { "type": "boolean" },
        "currentLat": { "type": "number" },
        "currentLng": { "type": "number" },
        "geoCell": { "type": "string", "description": "H3/S2 style spatial grid ID for fast lookups." },
        "rating": { "type": "number" },
        "totalTrips": { "type": "number" },
        "city": { "type": "string" },
        "documents": {
          "type": "object",
          "properties": {
            "dl": { "type": "string" },
            "rc": { "type": "string" },
            "insurance": { "type": "string" }
          }
        },
        "kycVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["driverId", "name", "phone", "vehicleNumber", "vehicleType"]
    },
    "ride": {
      "title": "Ride",
      "description": "A ride booking record with geospatial tracking and matching metadata.",
      "type": "object",
      "properties": {
        "rideId": { "type": "string" },
        "customerId": { "type": "string" },
        "driverId": { "type": "string", "nullable": true },
        "status": { "type": "string", "enum": ["requested", "accepted", "started", "completed", "cancelled"] },
        "pickup": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "geoCell": { "type": "string" }
          }
        },
        "dropoff": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "fare": { "type": "number" },
        "distance": { "type": "number" },
        "matchingScore": { "type": "number" },
        "otp": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "driver_location": {
      "title": "Driver Location",
      "description": "Real-time geospatial telemetry for a driver.",
      "type": "object",
      "properties": {
        "driverId": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "geoCell": { "type": "string" },
        "heading": { "type": "number" },
        "speed": { "type": "number" },
        "isOnline": { "type": "boolean" },
        "isAvailable": { "type": "boolean" },
        "rating": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["driverId", "lat", "lng", "isOnline", "geoCell"]
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "User profile data."
    },
    "/drivers/{driverId}": {
      "schema": { "$ref": "#/backend/entities/driver" },
      "description": "Driver profile and status data."
    },
    "/rides/{rideId}": {
      "schema": { "$ref": "#/backend/entities/ride" },
      "description": "Ride booking records."
    },
    "/driver_locations/{driverId}": {
      "schema": { "$ref": "#/backend/entities/driver_location" },
      "description": "Real-time driver GPS data."
    }
  }
}
