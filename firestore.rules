
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow access to users collection for profile management
    match /users/{userId} {
      allow read, write: if true;
    }

    // Allow access to rides collection for the booking workflow
    match /rides/{rideId} {
      allow read, write: if true;
    }

    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
